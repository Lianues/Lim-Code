{
  "name": "limcode",
  "displayName": "Lim Code",
  "description": "Lim Code 是一个 VS Code AI 编程助手插件，支持多渠道模型、工具调用、MCP 和 SubAgent 工作流。",
  "version": "1.2.8-nightly",
  "publisher": "Lianues",
  "icon": "resources/icon.png",
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "AI",
    "Chat",
    "Education",
    "Programming Languages",
    "Snippets",
    "Testing"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "limcode.openChat",
        "title": "LimCode: 打开聊天面板"
      },
      {
        "command": "limcode.context.addSelectionToInput",
        "title": "LimCode: 添加选中代码到输入框"
      },
      {
        "command": "limcode.newChat",
        "title": "新建对话",
        "icon": "$(add)"
      },
      {
        "command": "limcode.showHistory",
        "title": "对话历史",
        "icon": "$(history)"
      },
      {
        "command": "limcode.showSettings",
        "title": "设置",
        "icon": "$(settings-gear)"
      },
      {
        "command": "limcode.migrateConversationHistories",
        "title": "迁移旧对话历史",
        "icon": "$(history)",
        "category": "LimCode"
      },
      {
        "command": "limcode.diff.acceptAll",
        "title": "Accept All Changes",
        "icon": "$(check-all)",
        "category": "LimCode"
      },
      {
        "command": "limcode.diff.rejectAll",
        "title": "Reject All Changes",
        "icon": "$(close-all)",
        "category": "LimCode"
      },
      {
        "command": "limcode.diff.acceptBlock",
        "title": "Accept Diff Block...",
        "icon": "$(check)",
        "category": "LimCode"
      },
      {
        "command": "limcode.diff.rejectBlock",
        "title": "Reject Diff Block...",
        "icon": "$(close)",
        "category": "LimCode"
      },
      {
        "command": "limcode.diff.acceptCurrentBlock",
        "title": "Accept Current Diff Block",
        "category": "LimCode"
      },
      {
        "command": "limcode.diff.rejectCurrentBlock",
        "title": "Reject Current Diff Block",
        "category": "LimCode"
      },
      {
        "command": "limcode.diff.nextBlock",
        "title": "Go to Next Diff Block",
        "category": "LimCode"
      },
      {
        "command": "limcode.diff.prevBlock",
        "title": "Go to Previous Diff Block",
        "category": "LimCode"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "limcode.newChat",
          "when": "view == limcode.chatView",
          "group": "navigation@1"
        },
        {
          "command": "limcode.showHistory",
          "when": "view == limcode.chatView",
          "group": "navigation@2"
        },
        {
          "command": "limcode.showSettings",
          "when": "view == limcode.chatView",
          "group": "navigation@3"
        }
      ],
      "editor/title": [
        {
          "command": "limcode.diff.acceptAll",
          "when": "limcode.hasPendingDiff",
          "group": "navigation@1"
        },
        {
          "command": "limcode.diff.rejectAll",
          "when": "limcode.hasPendingDiff",
          "group": "navigation@2"
        },
        {
          "command": "limcode.diff.acceptBlock",
          "when": "limcode.hasPendingDiff",
          "group": "navigation@3"
        },
        {
          "command": "limcode.diff.rejectBlock",
          "when": "limcode.hasPendingDiff",
          "group": "navigation@4"
        }
      ]
    },
    "keybindings": [
      {
        "command": "limcode.diff.acceptCurrentBlock",
        "key": "ctrl+shift+y",
        "mac": "cmd+shift+y",
        "when": "limcode.hasPendingDiff && editorTextFocus"
      },
      {
        "command": "limcode.diff.rejectCurrentBlock",
        "key": "ctrl+shift+n",
        "mac": "cmd+shift+n",
        "when": "limcode.hasPendingDiff && editorTextFocus"
      },
      {
        "command": "limcode.diff.nextBlock",
        "key": "alt+]",
        "mac": "alt+]",
        "when": "limcode.hasPendingDiff && editorTextFocus"
      },
      {
        "command": "limcode.diff.prevBlock",
        "key": "alt+[",
        "mac": "alt+[",
        "when": "limcode.hasPendingDiff && editorTextFocus"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "limcode",
          "title": "Lim Code",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "views": {
      "limcode": [
        {
          "type": "webview",
          "id": "limcode.chatView",
          "name": "Lim Code",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "configuration": {
      "title": "Lim Code",
      "properties": {
        "limcode.activeChannelId": {
          "type": "string",
          "default": "",
          "scope": "machine",
          "description": "当前激活的模型渠道 ID（按机器保存，不参与 Settings Sync）"
        },
        "limcode.lastReadAnnouncementVersion": {
          "type": "string",
          "default": "",
          "description": "用户上次查看的公告版本（可同步）"
        },
        "limcode.toolsConfig": {
          "type": "object",
          "default": {},
          "description": "LimCode 工具与提示词等配置（可同步）"
        },
        "limcode.security": {
          "type": "object",
          "scope": "machine",
          "default": {
            "allowSkillDirectoryAccessViaExecuteCommand": false
          },
          "properties": {
            "allowSkillDirectoryAccessViaExecuteCommand": {
              "type": "boolean",
              "default": false,
              "markdownDescription": "高危调试开关。开启后，`execute_command` 不再拦截 Skill 目录与 `skill://` 访问，会绕过 `read_skill_resource` / `execute_skill_script` 的 manifest、hash、staging 和 argv 安全路径。仅在你完全理解风险并需要本机调试时开启。"
            }
          },
          "additionalProperties": false,
          "description": "LimCode 安全相关机器级配置（不参与 Settings Sync）"
        },
        "limcode.ui": {
          "type": "object",
          "default": {},
          "description": "LimCode UI 配置（可同步）"
        },
        "limcode.toolsEnabled": {
          "type": "object",
          "default": {},
          "description": "工具启用状态（可同步）"
        },
        "limcode.toolAutoExec": {
          "type": "object",
          "default": {},
          "description": "工具自动执行配置（可同步）"
        },
        "limcode.maxToolIterations": {
          "type": "number",
          "default": 50,
          "description": "单回合最大工具调用次数（可同步，-1 表示无限制）"
        },
        "limcode.defaultToolMode": {
          "type": "string",
          "default": "function_call",
          "enum": [
            "function_call",
            "xml",
            "json"
          ],
          "description": "默认工具模式（可同步）"
        },
        "limcode.proxy": {
          "type": "object",
          "default": {
            "enabled": false
          },
          "scope": "machine",
          "description": "代理设置（按机器保存，不参与 Settings Sync）"
        },
        "limcode.storagePath": {
          "type": "object",
          "default": {},
          "scope": "machine",
          "description": "自定义数据存储路径（按机器保存，不参与 Settings Sync）"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "build:backend": "npm run compile",
    "watch": "tsc -watch -p ./",
    "build:frontend": "cd frontend && npm run build",
    "dev:frontend": "cd frontend && npm run dev:local",
    "build": "npm run compile && npm run build:frontend",
    "test": "node scripts/run-jest.cjs",
    "test:watch": "node scripts/run-jest.cjs --watch",
    "test:coverage": "node scripts/run-jest.cjs --coverage",
    "test:diagnose-execute-command-order": "node scripts/run-jest.cjs test/unit/chat/tool_iteration_loop.execute_command_diagnostic.test.ts --runInBand",
    "release:prepare": "node scripts/prepare-release.cjs",
    "release:check": "node scripts/check-release.cjs",
    "release:verify": "npm run release:check && npm run compile && npx ast-grep scan && npm run build:frontend",
    "package:vsix": "npx @vscode/vsce package"
  },
  "dependencies": {
    "@vscode/codicons": "^0.0.43",
    "fast-xml-parser": "^4.5.0",
    "ignore": "^7.0.5",
    "nanoid": "^5.1.6",
    "node-notifier": "^10.0.1",
    "tree-kill": "^1.2.2",
    "typescript": "^5.9.3",
    "undici-types": "^6.21.0",
    "unified-llm-provider": "0.1.1",
    "yaml": "^2.8.1"
  },
  "devDependencies": {
    "@ast-grep/cli": "^0.43.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^24.10.2",
    "@types/vscode": "^1.74.0",
    "@vscode/vsce": "3.9.1",
    "jest": "^29.7.0",
    "ts-jest": "^29.4.6"
  },
  "keywords": [
    "agent",
    "ai",
    "autonomous",
    "chatgpt",
    "claude",
    "gemini",
    "coding",
    "dev",
    "keybindings",
    "mcp",
    "lim code",
    "limcode"
  ],
  "author": "Limerence",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "https://github.com/Lianues/Lim-Code"
  }
}
