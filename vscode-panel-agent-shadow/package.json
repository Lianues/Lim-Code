{
  "name": "vscode-panel-agent-shadow",
  "displayName": "VSCode Panel Agent Shadow",
  "description": "A minimal shadow VSCode Panel Agent extension used to discover the canonical panel trunk path.",
  "version": "0.0.1",
  "publisher": "local-shadow",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "vscode-panel-agent-shadow.openView",
        "title": "Panel Agent Shadow: Focus View"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "panelAgentShadow",
          "title": "Panel Agent Shadow",
          "icon": "resources/panel-agent-shadow.svg"
        }
      ]
    },
    "views": {
      "panelAgentShadow": [
        {
          "type": "webview",
          "id": "vscode-panel-agent-shadow.view",
          "name": "Helloween",
          "icon": "resources/panel-agent-shadow.svg"
        }
      ]
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "typescript": "^5.3.3"
  }
}
