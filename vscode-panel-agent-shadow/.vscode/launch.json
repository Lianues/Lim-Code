{
  // 为什么要改：最小 VSCode 插件需要一个清晰的本地启动入口，否则只能手动配置 Extension Development Host。
  // 怎么改：用 VSCode 官方扩展调试类型启动当前 shadow extension，并在启动前执行 npm: compile。
  // 目的是什么：让 Stage 1 的 Hello World Panel 可以通过 F5 验证，同时不引入 agent、runtime 或 Webview 通信逻辑。
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run Panel Agent Shadow Extension",
      "type": "extensionHost",
      "request": "launch",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}"
      ],
      "outFiles": [
        "${workspaceFolder}/dist/**/*.js"
      ],
      "preLaunchTask": "npm: compile"
    }
  ]
}
