{
  // 为什么要改：Stage 1 需要一个可编译的最小 VSCode 扩展，而不是直接写散落的 JavaScript。
  // 怎么改：把 Extension Host 入口从 src/extension-host 编译到 dist，并开启严格类型检查。
  // 目的是什么：让最小 Hello World 面板也走正式扩展编译路径，为后续协议和状态 owner 留出清晰边界。
  "compilerOptions": {
    "module": "commonjs",
    "target": "ES2020",
    "outDir": "dist",
    "lib": [
      "ES2020",
      "DOM"
    ],
    "sourceMap": true,
    "rootDir": "src/extension-host",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true
  },
  "include": [
    "src/extension-host/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    ".vscode-test"
  ]
}
