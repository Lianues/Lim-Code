{
  // 为什么要改：Stage 1 现在开始引入 src/protocol 作为 Webview 与 Extension Host 的共享边界类型。
  // 怎么改：把 rootDir 从 src/extension-host 提升到 src，并让 include 覆盖 src 下所有 TypeScript 文件。
  // 目的是什么：让协议类型和 Extension Host 入口一起被 TypeScript 检查，同时保持输出仍集中在 dist。
  "compilerOptions": {
    "module": "commonjs",
    "target": "ES2020",
    "outDir": "dist",
    "lib": [
      "ES2020",
      "DOM"
    ],
    "sourceMap": true,
    "rootDir": "src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true
  },
  "include": [
    "src/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    ".vscode-test"
  ]
}
