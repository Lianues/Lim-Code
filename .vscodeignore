# 开发文件
.vscode/**
.vscode-test/**
.gitignore
tsconfig.json
*.map
*.ts
!*.d.ts

# 发布包本地资料排除：这些文件只用于开发、审计或历史回滚，不应进入 VSIX。
# 为什么要加：docs/、两个修复资料目录、临时目录和旧 VSIX 会显著放大发布包并暴露内部过程资料。
# 怎么改：仅在 VS Code 打包层排除，不影响源码仓库里需要提交的代码与配置。
# 目的：让 1.2.2 上传包只包含运行时所需产物和面向用户的说明文本。
docs/**
# 为什么要改：项目级 .limcode/skills 只是开发工作区配置，不能作为 VSIX 运行时内置 Skill 泄漏进安装包。
# 怎么改：打包时排除整个 .limcode 目录；真正的内置 Skill 只从 resources/skills 发布。
# 目的：避免同一批 Skill 同时以项目配置和插件内置资产两种来源进入包内，造成来源语义混乱。
.limcode/**
2026年5月27日-修复资料/**
2026年5月28日 修复资料/**
.tmp/**
tmp/**
.kagent/**
Junk/**
ast-grep/**
sgconfig.yml
AGENTS.md
subagent-orchestration-skill/**
测试mcp.json
*.vsix

# 内置 Skill 运行时资产必须进入 VSIX。
# 为什么要改：resources/skills 是 builtin 来源的唯一发布载体，未来可能有人扩大 resources 排除规则。
# 怎么改：显式保留 resources/skills，确保 vsce 取反规则让内置 Skill 随插件发布。
# 目的：让新增内置 Skill 只需添加目录，不依赖隐式打包行为。
!resources/skills/**

# 锁文件
pnpm-lock.yaml
package-lock.json
yarn.lock

# 测试相关（不打包进扩展）
test/**
jest.config.cjs
tsconfig.jest.json
coverage/**
.jest-cache/**
.ts-jest/**
.cache/**

# 日志文件（本地调试产物不打包）
*.log
*.log.*
logs/**

# 后端源文件和文档（只需要 dist 中的编译结果）
backend/**
webview/**

# 前端源文件（只需要 dist）
frontend/src/**
frontend/node_modules/**
frontend/*.json
frontend/*.ts
frontend/*.html
frontend/tsconfig*.json
frontend/vite.config.ts
frontend/pnpm-lock.yaml
frontend/COMPONENT_ARCHITECTURE.md

# 忽略所有 node_modules，但保留需要的运行时依赖
node_modules/**
!node_modules/@vscode/**
!node_modules/@vscode/codicons/**
!node_modules/@vscode/codicons/dist/**
!node_modules/fast-xml-parser/**
!node_modules/nanoid/**
!node_modules/strnum/**
!node_modules/tree-kill/**
!node_modules/ignore/**
# 修改原因：Phase A 引入 unified-llm-provider 作为隔离 ProtocolAdapter PoC，VSIX 运行时 dynamic import 需要包文件真实存在。
# 修改方式：在排除 node_modules 后显式放回该 exact-pinned 依赖；UI/Monitor 仍不得直接 import 第三方类型。
# 目的：让 VSIX packaging / Extension Host smoke 覆盖真实依赖，而不是只在开发 node_modules 中通过。
!node_modules/unified-llm-provider/**
# 为什么要改：Skill frontmatter 解析和 read_skill 摘要序列化在运行时 require('yaml')。
# 怎么改：.vscodeignore 默认排除 node_modules 后，需要显式把 yaml 依赖放回 VSIX。
# 目的：避免安装后的扩展激活时报 Cannot find module 'yaml'。
!node_modules/yaml/**
!node_modules/node-notifier/**
!node_modules/growly/**
!node_modules/is-wsl/**
!node_modules/is-docker/**
!node_modules/semver/**
!node_modules/shellwords/**
!node_modules/uuid/**
!node_modules/which/**
!node_modules/isexe/**
