# 开发文件
.vscode/**
.vscode-test/**
.gitignore
tsconfig.json
*.map
*.ts
!*.d.ts

# 发布包本地资料排除：这些文件只用于开发、审计或历史回滚，不应进入 VSIX。
# 为什么要加：docs/、两个修复资料目录、临时目录和旧 VSIX 会显著放大发布包并暴露内部过程资料。
# 怎么改：仅在 VS Code 打包层排除，不影响源码仓库里需要提交的代码与配置。
# 目的：让 1.2.1 上传包只包含运行时所需产物和面向用户的说明文本。
docs/**
2026年5月27日-修复资料/**
2026年5月28日 修复资料/**
.tmp/**
tmp/**
Junk/**
ast-grep/**
sgconfig.yml
*.vsix

# 锁文件
pnpm-lock.yaml
package-lock.json
yarn.lock

# 测试相关（不打包进扩展）
test/**
jest.config.cjs
tsconfig.jest.json
coverage/**
.jest-cache/**
.ts-jest/**
.cache/**

# 日志文件（本地调试产物不打包）
*.log
*.log.*
logs/**

# 后端源文件和文档（只需要 dist 中的编译结果）
backend/**
webview/**

# 前端源文件（只需要 dist）
frontend/src/**
frontend/node_modules/**
frontend/*.json
frontend/*.ts
frontend/*.html
frontend/tsconfig*.json
frontend/vite.config.ts
frontend/pnpm-lock.yaml
frontend/COMPONENT_ARCHITECTURE.md

# 忽略所有 node_modules，但保留需要的运行时依赖
node_modules/**
!node_modules/@vscode/**
!node_modules/@vscode/codicons/**
!node_modules/@vscode/codicons/dist/**
!node_modules/fast-xml-parser/**
!node_modules/nanoid/**
!node_modules/strnum/**
!node_modules/tree-kill/**
!node_modules/ignore/**
!node_modules/node-notifier/**
!node_modules/growly/**
!node_modules/is-wsl/**
!node_modules/is-docker/**
!node_modules/semver/**
!node_modules/shellwords/**
!node_modules/uuid/**
!node_modules/which/**
!node_modules/isexe/**